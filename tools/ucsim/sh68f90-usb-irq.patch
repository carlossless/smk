+  // SH68F90 patch: the standard 8051 timer0/1 (TCON/TMOD/TL/TH @ 0x88-0x8d) and
+  // serial (SCON/SBUF @ 0x98/0x99) are NOT present on this chip -- it remaps
+  // those addresses to GPIO/clock SFRs (P5, LPDSEL, MAPPING, EXCON, DRVCON,
+  // P5DRV) and the USB EP1CON (0x99). Registering uCsim's models there would run
+  // phantom timer/UART logic on unrelated firmware writes. The real UART
+  // (SCON 0xd8 / SBUF 0xaa) and USB are modeled in interrupt.cc instead. Timer 2
+  // (0xc8) IS at the standard address and is still added by cl_uc52.
 
   add_hw(h= new cl_dreg(this, 0, "dreg"));
